{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": "../../",
    "paths": {
      "@haelabs/types": ["packages/types/src/index.ts"],
      "@haelabs/sdk": ["packages/sdk/src/index.ts"],
      "@haelabs/auth": ["packages/auth/src/index.ts"],
      "@haelabs/utils": ["packages/utils/src/index.ts"],
      "@haelabs/ui": ["packages/ui/src/index.ts"],
      "@petabase/*": ["apps/petabase/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "middleware.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
